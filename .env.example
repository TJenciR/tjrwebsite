# The component showcase is available automatically in development. Keep this
# false in production; set it true only for a temporary, access-controlled preview.
DESIGN_SYSTEM_SHOWCASE=false

# Local default: validate contact requests but do not send or persist them.
# Production must explicitly use `resend`; it never falls back to real delivery.
CONTACT_DELIVERY_MODE=development

# Required only when CONTACT_DELIVERY_MODE=resend. Configure these as server-only
# Vercel environment variables; never rename them with a NEXT_PUBLIC_ prefix.
# RESEND_API_KEY=
# CONTACT_RECIPIENT_EMAIL=
# CONTACT_SENDER_EMAIL=

# Vercel supplies VERCEL_ENV and VERCEL_URL automatically. Do not define them
# here. Preview URLs are used only as runtime Open Graph origins; the canonical
# production origin remains https://jenorichardtokoli.com.

# Never add direct contact details, provider secrets, or private-document paths
# to client-visible NEXT_PUBLIC_* variables.
